rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAuthorPlus() {
      return isSignedIn() && role() in ['author', 'editor', 'super_admin'];
    }

    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorPlus()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
